# -----------------------------------------------------------------------------
# Runtime (FastAPI reads these via pydantic-settings; see app/core/config.py)
# -----------------------------------------------------------------------------
APP_ENV=development
PUBLIC_HOST=localhost
NGINX_PORT=8005

# -----------------------------------------------------------------------------
# PostgreSQL — used by docker-compose for the db service; DATABASE_URL for the app
# -----------------------------------------------------------------------------
POSTGRES_DB=phone_validator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Inside Docker Compose, host "postgres" resolves to the db container.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/phone_validator

# -----------------------------------------------------------------------------
# OpenAI (LLM fallback for recoverable phone cases)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# -----------------------------------------------------------------------------
# Webhook — optional shared secret; if set, clients must send X-Webhook-Token
# -----------------------------------------------------------------------------
WEBHOOK_TOKEN=

# -----------------------------------------------------------------------------
# IP geolocation (10-digit local numbers need a country context)
# Free tier: https://ipinfo.io/signup — Lite API, country-level, no daily cap
# -----------------------------------------------------------------------------
IP_GEO_ENABLED=true
IP_GEO_DEFAULT_COUNTRY=US
IP_GEO_CACHE_TTL_SECONDS=86400
IP_GEO_TIMEOUT_SECONDS=3
IPINFO_TOKEN=

# -----------------------------------------------------------------------------
# Docker entrypoint — wait for Postgres before alembic + uvicorn
# -----------------------------------------------------------------------------
DB_WAIT_MAX_ATTEMPTS=30
DB_WAIT_SLEEP_SECONDS=2
